---
import { Image } from "astro:assets";

interface Props {
  title: string;
  subtitle: string;
  image: ImageMetadata | string; // Accepte l'objet d'image optimisé ou une chaîne classique
  height?: string;
  overlayMaxWidth?: string;
}

const {
  title,
  subtitle,
  image,
  height = "60vh",
  overlayMaxWidth = "700px",
} = Astro.props;

// On vérifie si l'image est un objet importé (optimisable) ou une simple chaîne de texte
const isOptimizedImage = typeof image !== "string";
---

<section
  class="hero"
  style={`height: ${height};`}
  role="region"
  aria-label="Hero section"
>
  <!-- Rendu adaptatif : Image optimisée Astro OU image classique en arrière-plan -->
  {
    isOptimizedImage ? (
      <Image
        src={image}
        alt={title}
        widths={[360, 720, 1200, 1920]}
        sizes="100vw"
        quality="high"
        loading="eager"
        class="hero-bg-image"
      />
    ) : (
      <div
        class="hero-bg-fallback"
        style={`background-image: url('${image}');`}
      />
    )
  }

  <!-- Contenu textuel et voile sombre -->
  <div class="overlay" style={`max-width: ${overlayMaxWidth};`}>
    <h1>{title}</h1>
    <p>{subtitle}</p>
  </div>
</section>

<style>
  .hero {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    min-height: 40vh;
    position: relative;
    overflow: hidden;
  }

  /* Positionnement absolu de l'image de fond optimisée */
  .hero-bg-image,
  .hero-bg-fallback {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  /* Support de l'effet parallaxe uniquement sur les écrans PC (Desktop) */
  @media (min-width: 1025px) {
    /* Note : L'effet parallaxe natif avec Image n'est pas possible en CSS pur, 
       ce fallback conserve le comportement initial pour les anciennes chaînes de caractères si besoin */
    .hero-bg-fallback {
      background-attachment: fixed;
    }
  }

  /* Voile sombre global par-dessus l'image */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2);
    pointer-events: none;
    z-index: 1;
  }

  .overlay {
    background: rgba(0, 0, 0, 0.5);
    color: white;
    padding: 2rem 3rem;
    border-radius: 12px;
    text-align: center;
    animation: fadeIn 0.6s ease;
    position: relative;
    z-index: 2;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .overlay h1 {
    margin: 0;
    font-size: clamp(1.75rem, 5vw, 4rem);
    line-height: 1.2;
    font-weight: 700;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .overlay p {
    margin-top: 1rem;
    font-size: clamp(0.95rem, 3vw, 1.1rem);
    line-height: 1.5;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  /* Tablette */
  @media (max-width: 1024px) {
    .overlay {
      padding: 1.5rem 2rem;
    }

    .overlay h1 {
      font-size: clamp(1.5rem, 4vw, 3rem);
    }

    .overlay p {
      font-size: clamp(0.9rem, 2.5vw, 1rem);
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero {
      min-height: 35vh;
    }

    .overlay {
      padding: 1.5rem 1.5rem;
      border-radius: 8px;
      max-width: 95% !important;
    }

    .overlay h1 {
      font-size: clamp(1.25rem, 4vw, 2rem);
    }

    .overlay p {
      font-size: clamp(0.85rem, 2.5vw, 0.95rem);
      margin-top: 0.75rem;
    }
  }

  /* Très petit écran */
  @media (max-width: 380px) {
    .hero {
      min-height: 30vh;
    }

    .overlay {
      padding: 1rem 1rem;
      max-width: 100% !important;
    }

    .overlay h1 {
      font-size: 1.25rem;
    }

    .overlay p {
      font-size: 0.8rem;
      margin-top: 0.5rem;
    }
  }
</style>
