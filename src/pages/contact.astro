---
import MainLayout from "../layouts/MainLayout.astro";
import { site } from "../data/site";
---

<MainLayout
  title="Contact institutionnel de Mohamé"
  description="Contactez Mohamé et l'AJRMO via les canaux institutionnels officiels : email, WhatsApp, téléphone et Facebook."
>
  <section class="contact-section">
    <div class="container">
      <header class="contact-header">
        <h1>Contact Institutionnel</h1>
        <p>
          Pour toute demande relative à Mohamé ou à l'AJRMO, merci d'utiliser
          les canaux officiels ci-dessous. Aucune saisie de message n'est
          possible directement sur ce site.
        </p>
      </header>

      <div class="note-card" role="note" aria-live="polite">
        <p>
          <strong>Important :</strong> cette page fournit des contacts institutionnels
          uniquement. Il n'y a pas de formulaire envoyé depuis le site.
        </p>
      </div>

      <div class="contact-info">
        <div class="info-block">
          <h3>✉️ Email</h3>
          <a
            href={`mailto:${site.email}`}
            aria-label={`Envoyer un email à ${site.email}`}
          >
            {site.email}
          </a>
        </div>

        <div class="info-block">
          <h3>👥 Facebook</h3>
          <a href={site.facebook} target="_blank" rel="noopener noreferrer">
            Mohamé village officiel
          </a>
        </div>

        <div class="info-block">
          <h3>📍 Adresse</h3>
          <p>Mohamé, Sous-Préfecture de Bonoua, Côte d'Ivoire</p>
        </div>
      </div>

      <section class="ajrmo-info" aria-labelledby="ajrmo-title">
        <h2 id="ajrmo-title">À propos de l'AJRMO</h2>
        <p>
          L'Association des Jeunes Ressortissants de Mohamé (AJRMO) porte la
          voix de la communauté et accompagne les projets locaux. Pour toute
          question institutionnelle, privilégiez les contacts ci-dessus.
        </p>
        <ul>
          <li>
            <strong>Mission :</strong> renforcer l'animation sociale, culturelle et
            économique du village.
          </li>
          <li>
            <strong>Orientation :</strong> relations publiques, projets communautaires,
            partenariats.
          </li>
          <li>
            <strong>Canal prioritaire :</strong> email ou WhatsApp pour les demandes
            officielles.
          </li>
        </ul>
      </section>
    </div>
  </section>
</MainLayout>

<style>
  .contact-section {
    padding: 4rem 1rem;
    background: #f8f9fa;
  }

  .container {
    max-width: 760px;
    margin: auto;
    padding: 0 1rem;
  }

  .contact-header {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .contact-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
    color: #003b5c;
    line-height: 1.2;
  }

  .contact-header p {
    font-size: clamp(0.95rem, 3vw, 1.1rem);
    color: #555;
    line-height: 1.7;
  }

  .note-card {
    background: #e7f1ff;
    border: 1px solid #c8def7;
    border-radius: 12px;
    padding: 1.75rem;
    margin-bottom: 2rem;
  }

  .note-card p {
    margin: 0;
    color: #1a3f5c;
    font-size: clamp(0.95rem, 2vw, 1rem);
    line-height: 1.8;
  }

  .contact-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .info-block {
    background: white;
    padding: 1.5rem;
    border-radius: 14px;
    border: 1px solid rgba(0, 59, 92, 0.08);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.04);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .info-block h3 {
    margin: 0;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: #003b5c;
    line-height: 1.3;
  }

  .info-block p,
  .info-block a {
    margin: 0;
    font-size: clamp(0.95rem, 2vw, 1rem);
    color: #555;
    line-height: 1.7;
    text-decoration: none;
    word-break: break-word;
  }

  .info-block a {
    color: #0077b6;
    transition: color 0.3s ease;
  }

  .info-block a:hover,
  .info-block a:focus-visible {
    color: #003b5c;
    text-decoration: underline;
    outline: none;
  }

  .ajrmo-info {
    background: white;
    padding: 2rem;
    border-radius: 14px;
    border: 1px solid rgba(0, 59, 92, 0.08);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.04);
  }

  .ajrmo-info h2 {
    margin-top: 0;
    margin-bottom: 1rem;
    color: #003b5c;
    font-size: clamp(1.5rem, 4vw, 1.9rem);
    line-height: 1.2;
  }

  .ajrmo-info p,
  .ajrmo-info ul {
    margin: 0;
    color: #555;
    font-size: clamp(0.95rem, 2vw, 1rem);
    line-height: 1.7;
  }

  .ajrmo-info ul {
    padding-left: 1.25rem;
    margin-top: 1rem;
  }

  .ajrmo-info li {
    margin-bottom: 0.85rem;
  }

  @media (max-width: 1024px) {
    .contact-section {
      padding: 3rem 1rem;
    }

    .contact-info {
      gap: 1rem;
    }
  }

  @media (max-width: 768px) {
    .contact-section {
      padding: 2.5rem 1rem;
    }

    .contact-header {
      margin-bottom: 1.75rem;
    }

    .contact-info {
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .note-card,
    .ajrmo-info {
      padding: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .contact-section {
      padding: 2rem 0.75rem;
    }

    .container {
      padding: 0 0.75rem;
    }

    .contact-header {
      margin-bottom: 1.5rem;
    }

    .contact-header h1 {
      font-size: 1.35rem;
      margin-bottom: 0.5rem;
    }

    .note-card,
    .ajrmo-info {
      padding: 1rem;
    }
  }

  @media (max-width: 380px) {
    .contact-section {
      padding: 1.5rem 0.5rem;
    }

    .container {
      padding: 0 0.5rem;
    }

    .contact-info {
      gap: 0.85rem;
    }
  }
</style>
