---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
import Card from "../components/Card.astro";

// Importation corrigée selon le chemin exact de votre dossier src/assets/images
import imagePlageHero from "../assets/images/plage-mohame-03.webp";
---

<MainLayout
  title="Village de Mohamé, patrimoine et développement"
  description="Découvrez le village de Mohamé : plage, canal, infrastructures, tourisme et actions communautaires portées by l'AJRMO."
>
  <Hero
    title="Portail officiel du village de Mohamé"
    subtitle="Bonoua · Sud-Comoé · Côte d'Ivoire"
    image={imagePlageHero}
    height="85vh"
  />

  <section class="intro">
    <div class="container">
      <h1>Mohamé</h1>

      <p>
        Mohamé est un village côtier situé dans la Sous-Préfecture de Bonoua, au
        sud-est de la Côte d'Ivoire.
      </p>

      <p>
        Entre l’océan Atlantique, le canal de Vridi et la forêt littorale, le
        village possède un patrimoine naturel exceptionnel ainsi qu’une forte
        dynamique communautaire portée notamment par l’AJRMO.
      </p>
    </div>
  </section>

  <section class="cards">
    <Card
      href="/patrimoine/plage"
      image="/images/plage/plage-mohame-03.webp"
      title="Plage"
    />

    <Card
      href="/patrimoine/canal"
      image="/images/canal/wide-view-canal-mohame-02.webp"
      title="Canal"
    />

    <Card
      href="/tourisme/hotels"
      image="/images/hotels/hotel-bethel-evasion.webp"
      title="Tourisme"
    />

    <Card
      href="/infrastructures/ecole"
      image="/images/ecole/ecole-primaire-mohame-01.webp"
      title="Éducation"
    />

    <Card
      href="/infrastructures/centre-sante"
      image="/images/sante/centre-sante-mohame-01.webp"
      title="Santé"
    />

    <Card
      href="/ajrmo"
      image="/images/ajrmo/logo-officiel-ajrmo.webp"
      title="AJRMO"
    />
  </section>

  <section class="developpement">
    <div class="container">
      <h2>Développement du village</h2>

      <div class="grid">
        <div>
          <img
            src="/images/autoroute/nouvelle-autoroute-abidjan-assinie-par-mohame01.webp"
            alt="Autoroute"
            loading="lazy"
            decoding="async"
          />
          <h3>Autoroute Abidjan – Assinie</h3>
        </div>

        <div>
          <img
            src="/images/base-maritime/operation-securite-plage-mohame.webp"
            alt="Base maritime"
            loading="lazy"
            decoding="async"
          />
          <h3>Base maritime</h3>
        </div>

        <div>
          <img
            src="/images/gendarmerie/poste-gendarmerie-mohame.webp"
            alt="Gendarmerie"
            loading="lazy"
            decoding="async"
          />
          <h3>Gendarmerie</h3>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .intro {
    padding: clamp(2rem, 8vw, 5rem) 1rem;
  }

  /* Correction du sélecteur ici : h1 au lieu de h2 */
  .intro h1 {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: 1.5rem;
    color: #003b5c;
    line-height: 1.2;
  }

  .intro p {
    font-size: clamp(0.95rem, 2.5vw, 1.05rem);
    line-height: 1.7;
    color: #555;
    margin-bottom: 1rem;
  }

  .container {
    max-width: 1200px;
    margin: auto;
    padding: 0 1rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .developpement {
    padding: clamp(2rem, 8vw, 5rem) 1rem;
  }

  .developpement h2 {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: 2rem;
    color: #003b5c;
    line-height: 1.2;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: clamp(1rem, 3vw, 2rem);
  }

  .grid > div {
    overflow: hidden;
    border-radius: 10px;
  }

  .grid h3 {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    margin-top: 1rem;
    color: #003b5c;
    line-height: 1.3;
  }

  .grid img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 10px;
    display: block;
  }

  /* Tablette */
  @media (max-width: 1024px) {
    .cards {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.25rem;
      padding: 1.5rem;
    }

    .grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.25rem;
    }

    .grid img {
      height: 180px;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .intro {
      padding: 2.5rem 0.75rem;
    }

    /* Correction h1 */
    .intro h1 {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      margin-bottom: 1rem;
    }

    .intro p {
      font-size: 0.95rem;
    }

    .cards {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      padding: 1rem;
    }

    .developpement {
      padding: 2.5rem 0.75rem;
    }

    .developpement h2 {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      margin-bottom: 1.5rem;
    }

    .grid {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
    }

    .grid img {
      height: 160px;
    }

    .grid h3 {
      font-size: 0.95rem;
      margin-top: 0.75rem;
    }
  }

  /* Petit écran */
  @media (max-width: 480px) {
    .cards {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 0.75rem;
    }

    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .grid img {
      height: 140px;
    }

    .grid h3 {
      font-size: 0.9rem;
    }
  }

  /* Très petit écran */
  @media (max-width: 380px) {
    .intro {
      padding: 1.5rem 0.5rem;
    }

    /* Correction h1 */
    .intro h1 {
      font-size: 1.25rem;
    }

    .cards {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      padding: 0.5rem;
    }

    .developpement {
      padding: 1.5rem 0.5rem;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .grid img {
      height: 120px;
    }
  }
</style>
