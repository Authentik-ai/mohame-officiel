---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";
---

<MainLayout
    title="Page introuvable"
    description="La page demandée est introuvable sur le site Mohamé Officiel."
>
    <section class="not-found">
        <div class="container">
            <div class="card">
                <p class="eyebrow">Erreur 404</p>
                <h1>Page introuvable</h1>
                <p>La page que vous cherchez n'existe pas ou a été déplacée.</p>
                <Button href="/">Retour à l'accueil</Button>
            </div>
        </div>
    </section>
</MainLayout>

<style>
    .not-found {
        min-height: 70vh;
        display: flex;
        align-items: center;
        padding: clamp(2rem, 6vw, 5rem) 1rem;
    }

    .container {
        max-width: 900px;
        margin: 0 auto;
        width: 100%;
    }

    .card {
        background: white;
        border-radius: 20px;
        padding: clamp(2rem, 5vw, 4rem);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 59, 92, 0.08);
        text-align: center;
    }

    .eyebrow {
        margin: 0 0 1rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.85rem;
        font-weight: 800;
        color: #0077b6;
    }

    h1 {
        margin: 0;
        font-size: clamp(2rem, 6vw, 3.5rem);
        line-height: 1.1;
        color: #003b5c;
    }

    p {
        margin: 1rem 0 0;
        font-size: clamp(0.98rem, 2.5vw, 1.1rem);
        color: #555;
        line-height: 1.7;
    }

    .card :global(.button) {
        margin-top: 1.75rem;
    }
</style>
